Instance: 7fe7c8d6-e40f-4e1a-b17b-b2af993a0f51
InstanceOf: PractitionerRolePortal
Usage: #inline
* meta.profile = "https://canonical.fhir.link/servicewell/wof-portal/StructureDefinition/practitioner-role-portal"
