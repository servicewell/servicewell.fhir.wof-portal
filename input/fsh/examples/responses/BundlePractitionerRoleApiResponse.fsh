* practitioner.display = "Tannlege/Spes. Endo Thomas Eide"
* organization.identifier.system = "https://canonical.fhir.link/servicewell/wof-portal/identifier-system/endpoint-identifier-system-for-organization/efaad744-9faa-4075-8aa9-bb03aad9291b"
