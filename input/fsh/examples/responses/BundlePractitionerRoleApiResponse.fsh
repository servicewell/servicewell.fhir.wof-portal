* extension[=].valueString = "Thomas er spesialist i endodonti, med mange års erfaring i behandling av rotkanaler og kompliserte tannskader. Han kombinerer høy faglig kompetanse med moderne teknologi for å sikre presise og skånsomme behandlinger. Thomas er kjent for sin rolige og profesjonelle tilnærming, og for å gi pasientene trygghet – selv ved mer avanserte inngrep."
* extension[+].url = "https://canonical.fhir.link/servicewell/wof-portal/StructureDefinition/ext-binary-reference"
