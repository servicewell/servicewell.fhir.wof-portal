* extension[0].url = "https://canonical.fhir.link/servicewell/wof-portal/StructureDefinition/ext-practitionerrole-description"
* extension[=].valueString = "Tom har bred erfaring innen allmenn­tannbehandling og er kjent for sin nøyaktighet og rolige tilnærming. Han er opptatt av å finne løsninger som passer hver enkelt pasient og bruker moderne teknologi for å sikre høy kvalitet på behandlingen. Toms mål er at alle skal forlate klinikken med et smil – både bokstavelig og billedlig."
* extension[+].url = "https://canonical.fhir.link/servicewell/wof-portal/StructureDefinition/ext-binary-reference"
* extension[=].valueReference = Reference(6816cce5-e9a7-4c88-8d68-5ed464c159d3)
