* practitioner.identifier.value = "505"
* practitioner.display = "Tannpleier Lars Jansen"
* organization.identifier.system = "https://canonical.fhir.link/servicewell/wof-portal/identifier-system/endpoint-identifier-system-for-organization/efaad744-9faa-4075-8aa9-bb03aad9291b"
* organization.identifier.value = "578"
* organization.display = "Tannpleier Ruth Ellen Brubakken"
* code = $csPractitionerRole#hygienist "Tannpleier"
* code.text = "Tannpleier"
* healthcareService = Reference(HealthcareService/2a2af34c-31d2-4b15-aa4b-59f6a559bc5e) "Service-O Sandvika"

Instance: e0454fdc-43f0-4031-a7f8-24ab45afbbba
InstanceOf: PractitionerRolePortal
Usage: #inline
* meta.profile = "https://canonical.fhir.link/servicewell/wof-portal/StructureDefinition/practitioner-role-portal"
